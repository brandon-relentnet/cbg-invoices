# ==========================================================================
# App URLs
# ==========================================================================
APP_ENV=development
APP_BASE_URL=http://localhost:5173
BACKEND_BASE_URL=http://localhost:8000

# ==========================================================================
# Database (shared between app and Logto, separate databases)
# ==========================================================================
POSTGRES_USER=invoice
POSTGRES_PASSWORD=change-me-locally
POSTGRES_DB=invoice_portal
DATABASE_URL=postgresql+asyncpg://invoice:change-me-locally@postgres:5432/invoice_portal

# ==========================================================================
# Logto (self-hosted in this stack)
#
# First-time setup:
#   1. docker compose up -d
#   2. Open http://localhost:3002 - create initial admin account
#   3. Create an M2M app with Management API access, paste ID/secret below
#   4. Run: make logto-setup
#   5. Append the generated LOGTO_APP_ID and LOGTO_RESOURCE below
# ==========================================================================
LOGTO_ENDPOINT=http://localhost:3001
LOGTO_ADMIN_ENDPOINT=http://localhost:3002

# Server-to-server URL for backend → Logto calls (JWKS fetch, setup script,
# userinfo). In Docker dev this must be the service hostname because
# `localhost` inside the backend container points to the backend itself.
# In production, set this to the same value as LOGTO_ENDPOINT.
LOGTO_INTERNAL_URL=http://logto:3001

# M2M credentials for the setup script (from Logto admin console)
LOGTO_M2M_APP_ID=
LOGTO_M2M_APP_SECRET=

# Generated by `make logto-setup`
LOGTO_APP_ID=
LOGTO_RESOURCE=https://invoice-api.cambridgebg.com

# Frontend needs these (Vite env vars)
VITE_LOGTO_ENDPOINT=http://localhost:3001
VITE_LOGTO_APP_ID=
VITE_LOGTO_RESOURCE=https://invoice-api.cambridgebg.com
VITE_API_BASE_URL=http://localhost:8000

# ==========================================================================
# Anthropic (invoice extraction)
# Get from: https://console.anthropic.com/
# ==========================================================================
ANTHROPIC_API_KEY=
EXTRACTION_MODEL=claude-sonnet-4-5

# ==========================================================================
# Cloudflare R2 (PDF storage)
# Get from: https://dash.cloudflare.com/ -> R2 -> Manage API Tokens
# ==========================================================================
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=cambridge-invoices
R2_ENDPOINT=https://account_id.r2.cloudflarestorage.com

# ==========================================================================
# Postmark (inbound email -> webhook)
# Get from: https://account.postmarkapp.com/servers/{id}/inbound
# ==========================================================================
POSTMARK_WEBHOOK_SECRET=

# ==========================================================================
# QuickBooks Online
# Get from: https://developer.intuit.com/app/developer/myapps
#
# IMPORTANT: Start in sandbox mode. Switch to production only when ready
# to connect Cambridge's real QBO company.
# ==========================================================================
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
QBO_ENVIRONMENT=sandbox
QBO_REDIRECT_URI=http://localhost:8000/api/qbo/callback
QBO_DEFAULT_EXPENSE_ACCOUNT_ID=
